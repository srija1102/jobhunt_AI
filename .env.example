# Copy this file to .env.local for local development
# In Vercel: add these in Project Settings → Environment Variables

# 1. Anthropic API Key (for AI resume tailoring)
#    Get it at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 2. RapidAPI Key (for real job scraping from LinkedIn, Indeed, Glassdoor)
#    Get it at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
#    Free tier: 200 requests/month | Basic: $10/month for 3,000 requests
RAPIDAPI_KEY=your-rapidapi-key-here
