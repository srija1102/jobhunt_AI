{
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/scrape", "destination": "/api/scrape" },
    { "source": "/api/tailor", "destination": "/api/tailor" },
    { "source": "/api/score",  "destination": "/api/score"  },
    { "source": "/api/h1b",    "destination": "/api/h1b"    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
